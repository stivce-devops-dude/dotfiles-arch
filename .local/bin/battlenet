#!/bin/bash
pkill -f 'Agent.exe|Battle.net.exe' 2>/dev/null

PROTON_DIR="$HOME/.local/share/Steam/compatibilitytools.d"
LATEST_PROTON=$(ls -t "$PROTON_DIR"/UMU-Proton-* 2>/dev/null | head -1)

if [ -z "$LATEST_PROTON" ]; then
    echo "Error: No UMU-Proton installation found in $PROTON_DIR"
    exit 1
fi

exec umu-run "$LATEST_PROTON/proton" run "$HOME/Games/umu/battlenet/drive_c/Program Files (x86)/Battle.net/Battle.net.exe" "$@"
