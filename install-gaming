#!/bin/bash
set -euo pipefail

echo "--- Starting Gaming Setup for Arch + Nvidia + Hyprland ---"

has_dgpu() {
    if lspci 2>/dev/null | grep -qiE 'geforce.*(4070|4080|4090|RTX)'; then
        return 0
    fi
    if command -v nvidia-smi &>/dev/null && nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | grep -qiE '4070|4080|4090|RTX'; then
        return 0
    fi
    return 1
}

if ! grep -q "^\[multilib\]" /etc/pacman.conf; then
    echo "Enabling [multilib] repository..."
    sudo sed -i '/\[multilib\]/,/Include/s/^#//' /etc/pacman.conf
fi

echo "Updating system..."
sudo pacman -Syu --noconfirm

if has_dgpu; then
    echo "RTX 40-series GPU detected. Installing gaming packages..."

    echo "Installing Nvidia/Vulkan dependencies..."
    sudo pacman -S --needed --noconfirm \
        nvidia-utils lib32-nvidia-utils \
        vulkan-icd-loader lib32-vulkan-icd-loader \
        lib32-opencl-nvidia nvidia-settings 2>/dev/null || true

    echo "Installing UMU-Launcher and Wine libraries..."
    sudo pacman -S --needed --noconfirm \
        umu-launcher wine-staging winetricks \
        lib32-gnutls lib32-libldap lib32-libgpg-error \
        lib32-sqlite lib32-libpulse lib32-alsa-plugins \
        python-protobuf gamescope

    echo "Installing XWayland..."
    sudo pacman -S --needed --noconfirm xorg-xwayland

    echo "Checking for Steam proton..."
    if [ ! -d "$HOME/.local/share/Steam/compatibilitytools.d/UMU-Proton-10.0-4" ]; then
        echo "Warning: UMU-Proton not found in Steam compatibility tools"
        echo "Please ensure Steam is installed with Proton support"
    fi

    echo "Installing Battle.net..."
    BATTLENET_INSTALLER="/tmp/Battle.net-Setup.exe"
    if [ ! -f "$BATTLENET_INSTALLER" ]; then
        echo "Downloading Battle.net installer..."
        curl -L -o "$BATTLENET_INSTALLER" "https://www.battle.net/download/getInstallerForGame?os=win"
    fi

    echo "Running Battle.net installer with UMU-Proton..."
    GAMEID=battlenet umu-run ~/.local/share/Steam/compatibilitytools.d/UMU-Proton-10.0-4/proton run "$BATTLENET_INSTALLER"

    BATTLENET_EXE="$HOME/Games/umu/battlenet/drive_c/Program Files (x86)/Battle.net/Battle.net.exe"
    while [ ! -f "$BATTLENET_EXE" ]; do
        echo "Waiting for Battle.net installation to complete..."
        sleep 5
    done

    echo "Creating battlenet launcher script..."
    mkdir -p "$HOME/.local/bin"
    cat > "$HOME/.local/bin/battlenet" << 'EOF'
#!/bin/bash
pkill -f 'Agent.exe|Battle.net.exe' 2>/dev/null
exec umu-run ~/.local/share/Steam/compatibilitytools.d/UMU-Proton-10.0-4/proton run "$HOME/Games/umu/battlenet/drive_c/Program Files (x86)/Battle.net/Battle.net.exe" "$@"
EOF
    chmod +x "$HOME/.local/bin/battlenet"

    echo "Creating desktop entry for fuzzel..."
    mkdir -p "$HOME/.local/share/applications"
    cat > "$HOME/.local/share/applications/battlenet.desktop" << 'EOF'
[Desktop Entry]
Type=Application
Name=Battle.net
Comment=Blizzard Battle.net Launcher
Exec=/home/sn0w/.local/bin/battlenet
Icon=/usr/share/icons/WhiteSur/apps/scalable/battlenet.svg
Terminal=false
Categories=Game;
EOF

    echo "Installing WoWUp..."
    if command -v yay &> /dev/null; then
        yay -S --noconfirm --mflags "--noconfirm" wowup-cf-bin
    elif command -vparu &> /dev/null; then
        paru -S --noconfirm wowup-cf-bin
    else
        echo "yay/paru not found. Run: yay -S wowup-cf-bin"
    fi

    echo "Installing Prism Launcher..."
    if command -v yay &> /dev/null; then
        yay -S --noconfirm --mflags "--noconfirm" prismlauncher
    elif command -vparu &> /dev/null; then
        paru -S --noconfirm prismlauncher
    else
        echo "yay/paru not found. Run: yay -S prismlauncher"
    fi
else
    echo "No RTX 40-series GPU detected. Skipping gaming packages."
fi

echo "------------------------------------------------------"
echo "INSTALLATION COMPLETE!"
echo ""
echo "Launchers:"
echo "  - battlenet       (Battle.net launcher)"
echo "  - wowup           (WoW addon manager)"
echo "  - prismlauncher   (Minecraft launcher)"
echo "------------------------------------------------------"
